        <mxCell id="iSell" value="[U] Продать токены&#10;на вторичном рынке&#10;safeTransferFrom()" style="rounded=1;arcSize=25;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" vertex="1" parent="poolInvestor">
